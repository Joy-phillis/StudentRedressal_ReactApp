{
  "expo": {
    "name": "student-redressal-app",
    "slug": "student-redressal-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon2.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
